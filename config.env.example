# ==========================================
# Workflow Directories (optional configuration)
# ==========================================
# These are currently hardcoded but can be extended in the future

# Input directories:
# - warranty/maintenance: input_pdfs/
# - pdf_merge: input_pdfs_merge/

# Output directories:
# - warranty/maintenance: output_pdfs/
# - pdf_merge: output_pdfs_merge/

# Failed files directories:
# - warranty: failed_pdfs/
# - maintenance: failed_pdfs/
# - pdf_merge: failed_pdfs_merge/
