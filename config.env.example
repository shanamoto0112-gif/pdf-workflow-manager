# ==========================================
# Recipient Email Configuration
# ==========================================

# WARRANTY workflow recipient
RECIPIENT_EMAIL_WARRANTY=warranty.japan@scania.com
# If not set, defaults to: warranty.japan@example.com

# MAINTENANCE workflow recipient
RECIPIENT_EMAIL_MAINTENANCE=contracts.japan@scania
